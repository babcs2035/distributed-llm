{
  "model": {
    "name": "meta-llama/Llama-3.1-70B",
    "format": "safetensors",
    "overrides": {
      "num_hidden_layers": 80
    }
  },
  "cluster": {
    "master_addr": "192.168.1.100",
    "master_port": 29500,
    "hosts_file": "hosts.txt"
  },
  "ssh": {
    "user": "user"
  },
  "docker": {
    "image_name": "llm-pipeline-image:latest",
    "registry_port": "5000"
  },
  "deploy": {
    "work_dir": "~/workspace/ktakahashi"
  }
}
